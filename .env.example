APP_PORT=8081

DB_HOST=localhost
DB_PORT=5432
DB_USER=wormhole_user
DB_PASSWORD=replace-with-password
DB_NAME=wormhole
DB_SSLMODE=disable

# JWT 配置
JWT_SECRET=replace-with-secure-random-secret
JWT_EXPIRE_HOURS=10



# Keycloak SSO（启用后 /auth/register 与 /auth/login 不再注册，改用 /auth/sso/login）
KEYCLOAK_ENABLED=false
# Keycloak realm issuer，例如：http://localhost:8080/realms/wormhole
KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/wormhole
KEYCLOAK_CLIENT_ID=wormhole-backend
KEYCLOAK_CLIENT_SECRET=replace-with-keycloak-client-secret
# 必须与 Keycloak Client 的 Valid redirect URIs 完全匹配
KEYCLOAK_REDIRECT_URL=http://localhost:8081/api/v1/auth/sso/callback
# 登录完成后允许跳回的前端根地址
KEYCLOAK_FRONTEND_URL=http://localhost:5173
KEYCLOAK_SCOPES=openid,profile,email
# 至少 32 字节随机值；示例生成：openssl rand -base64 32
KEYCLOAK_STATE_SECRET=replace-with-at-least-32-byte-random-state-secret
KEYCLOAK_STATE_COOKIE_NAME=wormhole_oidc_state
KEYCLOAK_HTTP_TIMEOUT_SECONDS=10

# 后端签发给浏览器的 HttpOnly 会话 Cookie
AUTH_COOKIE_NAME=wormhole_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
CORS_ALLOWED_ORIGINS=http://localhost:5173
